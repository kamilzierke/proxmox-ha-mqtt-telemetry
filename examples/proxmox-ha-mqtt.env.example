# Copy this file to /etc/proxmox-ha-mqtt.env on the Proxmox host.
# Keep the real file readable only by root because it contains MQTT credentials.
#
# Required packages on Proxmox:
#   apt install -y lm-sensors python3 python3-paho-mqtt mosquitto-clients smartmontools

# MQTT broker address. If you use the Home Assistant Mosquitto add-on,
# this is usually the IP address of the Home Assistant instance, not Proxmox.
MQTT_HOST="192.168.1.100"
MQTT_PORT="1883"

# MQTT credentials. Create a dedicated broker user if possible.
MQTT_USER="proxmox_mqtt"
MQTT_PASS="change_me"

# Logical node name used in MQTT topics and Home Assistant device names.
NODE_NAME="pve"

# Home Assistant MQTT Discovery prefix. Default in HA is usually homeassistant.
DISCOVERY_PREFIX="homeassistant"

# Base topic for lm-sensors / hwmon telemetry.
# Used by scripts/proxmox-ha-hwmon-daemon.py.
BASE_TOPIC="proxmox/pve/hwmon"

# Base topic for SMART/NVMe telemetry.
# Used by scripts/proxmox-ha-smart-daemon.py.
SMART_BASE_TOPIC="proxmox/pve/smart"

# How often each daemon reads sensors and publishes state, in seconds.
# Both daemons run as long-lived systemd services (not timers) and loop
# internally, holding a single MQTT connection open the whole time.
HWMON_INTERVAL_SECONDS="60"
SMART_INTERVAL_SECONDS="300"
